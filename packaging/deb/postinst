#!/usr/bin/env bash
set -euo pipefail

LOG_FILE="/var/log/wps-read-aloud-install.log"
mkdir -p /var/log
exec > >(tee -a "${LOG_FILE}") 2>&1
echo "[$(date '+%Y-%m-%d %H:%M:%S')] postinst $*"

SERVICE_NAME="@SERVICE_NAME@"
LEGACY_SERVICE_NAME="@LEGACY_SERVICE_NAME@"
REGISTER_BIN="@REGISTER_BIN@"
LEGACY_SERVICE_FILE="/lib/systemd/system/${LEGACY_SERVICE_NAME}"
LEGACY_REGISTER_BIN="/usr/bin/wps-read-aloud-register"
APP_DIR="@APP_ROOT@"

legacy_file_owned_by_project() {
  local path="$1"
  [[ -f "${path}" ]] || return 1
  grep -Eq 'wps-read-aloud|wps-tts-daemon|文档朗读助手' "${path}" 2>/dev/null
}

remove_path_if_inside_app_dir() {
  local path="$1"
  case "${path}" in
    "${APP_DIR}/"*) rm -rf "${path}" || true ;;
  esac
}

if [[ -f "${LEGACY_SERVICE_FILE}" ]] && {
  grep -q "wps-read-aloud" "${LEGACY_SERVICE_FILE}" 2>/dev/null ||
  grep -q "wps-tts-daemon" "${LEGACY_SERVICE_FILE}" 2>/dev/null
}; then
  systemctl disable --now "${LEGACY_SERVICE_NAME}" || true
  rm -f "${LEGACY_SERVICE_FILE}" || true
fi

if legacy_file_owned_by_project "${LEGACY_REGISTER_BIN}"; then
  rm -f "${LEGACY_REGISTER_BIN}" || true
fi

remove_path_if_inside_app_dir "${APP_DIR}/engines/piper"
remove_path_if_inside_app_dir "${APP_DIR}/engines/espeak"
remove_path_if_inside_app_dir "${APP_DIR}/engines/espeak-ng"
remove_path_if_inside_app_dir "${APP_DIR}/voices/piper"
remove_path_if_inside_app_dir "${APP_DIR}/voices/espeak"
remove_path_if_inside_app_dir "${APP_DIR}/docs"
remove_path_if_inside_app_dir "${APP_DIR}/.wps-read-aloud-zhangjingyao"

systemctl daemon-reload || true
systemctl enable "${SERVICE_NAME}" || true
systemctl restart "${SERVICE_NAME}" || systemctl start "${SERVICE_NAME}" || true

touch "${APP_DIR}/.wps-read-aloud-comate"

"${REGISTER_BIN}" --all-users || true

expected_version="$(
  sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "${APP_DIR}/version.json" 2>/dev/null | head -n 1
)"
if [[ -z "${expected_version}" ]]; then
  expected_version="unknown"
fi

health_ok=0
for i in 1 2 3 4 5; do
  health="$(
    exec 3<>/dev/tcp/127.0.0.1/19860
    printf 'GET /health HTTP/1.0\r\nHost: 127.0.0.1\r\n\r\n' >&3
    cat <&3
  )" 2>/dev/null || health=""
  if echo "${health}" | grep -q '"ok":true' && \
     echo "${health}" | grep -q "\"version\":\"${expected_version}\"" && \
     ! echo "${health}" | grep -q '"engine":"none"'; then
    echo "wps-read-aloud service health check passed: ${health}"
    health_ok=1
    break
  fi
  sleep 1
done

if [[ "${health_ok}" -ne 1 ]]; then
  echo "wps-read-aloud installed, but service health check did not pass yet."
  echo "The WPS add-in is installed, but read-aloud may not work until the service is healthy."
  echo "Check logs with: journalctl -u ${SERVICE_NAME} -n 80 --no-pager"
fi

selftest_ok=0
if [[ "${health_ok}" -eq 1 ]]; then
  selftest="$(
    exec 3<>/dev/tcp/127.0.0.1/19860
    printf 'GET /selftest HTTP/1.0\r\nHost: 127.0.0.1\r\n\r\n' >&3
    cat <&3
  )" 2>/dev/null || selftest=""
  if echo "${selftest}" | grep -q '"ok":true'; then
    echo "wps-read-aloud synthesis self-test passed: ${selftest}"
    selftest_ok=1
  else
    echo "wps-read-aloud service is running, but synthesis self-test did not pass."
    echo "Read-aloud may not work until the bundled engine/model issue is fixed."
    echo "Check logs with: journalctl -u ${SERVICE_NAME} -n 120 --no-pager"
  fi
fi

audio_probe="$(
  exec 3<>/dev/tcp/127.0.0.1/19860
  printf 'POST /audio/probe HTTP/1.0\r\nHost: 127.0.0.1\r\nContent-Length: 0\r\n\r\n' >&3
  cat <&3
)" 2>/dev/null || audio_probe=""

if echo "${audio_probe}" | grep -q '"selected":'; then
  echo "wps-read-aloud audio player probe completed: ${audio_probe}"
else
  echo "wps-read-aloud audio player probe did not complete."
  echo "The service will probe again on first playback if needed."
fi

echo "WPS 文档朗读助手 installed. Developer: Zhang Jingyao. Release date: 20260521."
echo "If WPS is already open, restart WPS to load the add-in."
echo "Install log: ${LOG_FILE}"
