<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui" onLoad="ribbon.OnAddinLoad">
  <ribbon>
    <tabs>
      <tab id="wpsReadAloudTab" label="文档朗读">
        <group id="readGroup" label="朗读">
          <button id="speakDocument" label="全文朗读" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="全文朗读" supertip="从文档开头按完整语句朗读全文，并同步选中当前语句。"/>
          <button id="speakFromCursor" label="当前位置朗读" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="当前位置朗读" supertip="从当前光标位置或选区起点开始朗读到文档结尾。"/>
          <button id="speakSelection" label="选区朗读" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="选区朗读" supertip="按完整语句朗读当前选中的文字，并同步选中文档中的当前语句。"/>
        </group>
        <group id="controlGroup" label="播放控制">
          <button id="pauseSpeak" label="暂停朗读" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="暂停朗读" supertip="暂停当前朗读。"/>
          <button id="resumeSpeak" label="继续朗读" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="继续朗读" supertip="继续当前朗读。"/>
          <button id="stopSpeak" label="停止朗读" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="停止朗读" supertip="停止当前朗读。"/>
        </group>
        <group id="settingGroup" label="朗读设置">
          <menu id="rateMenu" label="朗读语速" size="large" getImage="ribbon.GetImage" screentip="朗读语速" supertip="选择朗读语速，默认 1.0x。">
            <button id="rate06" label="0.6x" onAction="ribbon.OnAction"/>
            <button id="rate08" label="0.8x" onAction="ribbon.OnAction"/>
            <button id="rate10" label="1.0x（默认）" onAction="ribbon.OnAction"/>
            <button id="rate12" label="1.2x" onAction="ribbon.OnAction"/>
            <button id="rate14" label="1.4x" onAction="ribbon.OnAction"/>
            <button id="rate16" label="1.6x" onAction="ribbon.OnAction"/>
          </menu>
          <menu id="volumeMenu" label="朗读音量" size="large" getImage="ribbon.GetImage" screentip="朗读音量" supertip="选择朗读音量，默认 80%。">
            <button id="volume40" label="40%" onAction="ribbon.OnAction"/>
            <button id="volume60" label="60%" onAction="ribbon.OnAction"/>
            <button id="volume80" label="80%（默认）" onAction="ribbon.OnAction"/>
            <button id="volume100" label="100%" onAction="ribbon.OnAction"/>
          </menu>
        </group>
        <group id="serviceGroup" label="服务">
          <button id="checkStatus" label="状态检查" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="状态检查" supertip="检查本地朗读服务、语音引擎和播放器探测结果。"/>
          <button id="aboutAddin" label="关于朗读" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="关于朗读" supertip="查看加载项名称、版本、开发者和说明文档链接。"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
