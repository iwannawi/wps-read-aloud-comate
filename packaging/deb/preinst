#!/usr/bin/env bash
set -euo pipefail

LOG_FILE="/var/log/wps-read-aloud-install.log"
mkdir -p /var/log
exec > >(tee -a "${LOG_FILE}") 2>&1
echo "[$(date '+%Y-%m-%d %H:%M:%S')] preinst $*"

APP_DIR="@APP_ROOT@"
CONFIG_DIR="@CONFIG_DIR@"
SERVICE_FILE="/lib/systemd/system/wps-tts.service"
REGISTER_BIN="/usr/bin/wps-read-aloud-register"
MARKER="${APP_DIR}/.wps-read-aloud-comate"
LEGACY_MARKER="${APP_DIR}/.wps-read-aloud-zhangjingyao"
PORT="19860"

is_upgrade_or_reinstall() {
  [[ "${1:-}" = "upgrade" || "${1:-}" = "install" ]]
}

owned_app_dir() {
  [[ -f "${MARKER}" || -f "${LEGACY_MARKER}" ]]
}

if is_upgrade_or_reinstall "${1:-}"; then
  if (
    exec 3<>/dev/tcp/127.0.0.1/${PORT}
  ) 2>/dev/null; then
    if ! systemctl is-active --quiet wps-tts.service 2>/dev/null; then
      echo "安装已停止：127.0.0.1:${PORT} 已被其他程序占用。"
      echo "为避免影响其他软件，请释放该端口后再安装。"
      exit 1
    fi
  fi

  if [[ -e "${APP_DIR}" && ! owned_app_dir ]]; then
    echo "安装已停止：${APP_DIR} 已存在，但不是本安装包创建的目录。"
    echo "为避免覆盖其他软件或人工文件，请先备份并移走该目录。"
    exit 1
  fi

  if [[ -e "${SERVICE_FILE}" ]] && ! grep -q "${APP_DIR}/daemon/wps-tts-daemon" "${SERVICE_FILE}" 2>/dev/null && ! grep -q "/opt/wps-read-aloud/daemon/wps-tts-daemon" "${SERVICE_FILE}" 2>/dev/null; then
    echo "安装已停止：${SERVICE_FILE} 已存在，且不是本项目的服务文件。"
    echo "请先确认该服务来源，避免覆盖其他软件。"
    exit 1
  fi

  if [[ -e "${REGISTER_BIN}" ]] && ! grep -q "ADDIN_NAME=\"wps-read-aloud\"" "${REGISTER_BIN}" 2>/dev/null; then
    echo "安装已停止：${REGISTER_BIN} 已存在，且不是本项目脚本。"
    echo "请先确认该文件来源，避免覆盖其他软件。"
    exit 1
  fi

  if [[ -e "${CONFIG_DIR}" && ! -f "${CONFIG_DIR}/config.yaml" ]]; then
    echo "安装已停止：${CONFIG_DIR} 已存在，但不包含本项目配置文件。"
    echo "请先确认该目录来源，避免覆盖其他软件配置。"
    exit 1
  fi

  while IFS=: read -r name _ uid _ _ home shell; do
    if [[ "${uid}" -ge 1000 && -d "${home}" && "${shell}" != */nologin && "${shell}" != */false ]]; then
      js_dir="${home}/.local/share/Kingsoft/wps/jsaddons"
      for file in "${js_dir}/publish.xml" "${js_dir}/jsplugins.xml"; do
        if [[ -f "${file}" ]] && grep -q 'name="wps-read-aloud"' "${file}"; then
          if ! grep -q '127.0.0.1:19860' "${file}" && ! grep -q "${APP_DIR}" "${file}" && ! grep -q '/opt/wps-read-aloud' "${file}" && ! grep -q 'jsaddons/wps-read-aloud_' "${file}"; then
            echo "安装已停止：用户 ${name} 的 WPS 加载项配置中已有同名 wps-read-aloud，但来源不是本项目。"
            echo "文件：${file}"
            echo "请先确认该加载项来源，避免覆盖其他插件。"
            exit 1
          fi
        fi
      done
    fi
  done < /etc/passwd
fi
