#!/usr/bin/env bash
set -euo pipefail

LOG_FILE="/var/log/wps-read-aloud-install.log"
mkdir -p /var/log
exec > >(tee -a "${LOG_FILE}") 2>&1
echo "[$(date '+%Y-%m-%d %H:%M:%S')] postrm $*"

systemctl daemon-reload || true

if [[ "${1:-}" = "purge" ]]; then
  if [[ -f /opt/wps-read-aloud/.wps-read-aloud-zhangjingyao ]]; then
    rm -rf /opt/wps-read-aloud
  else
    echo "Skip removing /opt/wps-read-aloud because ownership marker is missing."
  fi
  rm -rf /etc/wps-read-aloud
  rm -rf /var/lib/wps-read-aloud
fi
