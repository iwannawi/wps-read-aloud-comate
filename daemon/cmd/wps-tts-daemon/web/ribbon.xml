<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui" onLoad="ribbon.OnAddinLoad">
  <ribbon>
    <tabs>
      <tab id="wpsReadAloudTab" label="文档朗读">
        <group id="readControlGroup" label="朗读控制">
          <button id="startSpeak" label="开始朗读" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="开始朗读" supertip="按当前朗读模式从光标位置或文档起点开始朗读。"/>
          <button id="stopSpeak" label="停止朗读" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="停止朗读" supertip="停止当前朗读任务。"/>
        </group>
        <group id="readModeGroup" label="朗读范围">
          <toggleButton id="modeContinuous" getLabel="ribbon.GetLabel" size="large" getImage="ribbon.GetImage" getPressed="ribbon.GetPressed" onAction="ribbon.OnAction" screentip="连页朗读" supertip="默认模式。从当前光标处朗读到文档末尾；没有光标时从文档开头朗读。"/>
          <toggleButton id="modePage" getLabel="ribbon.GetLabel" size="large" getImage="ribbon.GetImage" getPressed="ribbon.GetPressed" onAction="ribbon.OnAction" screentip="当页朗读" supertip="从当前光标处朗读到当前页末尾；没有光标时从当前页开头朗读到当前页末尾。"/>
        </group>
        <group id="settingGroup" label="朗读设置">
          <menu id="rateMenu" getLabel="ribbon.GetLabel" size="large" getImage="ribbon.GetImage" screentip="朗读语速" supertip="选择朗读语速，默认 1x。">
            <button id="rate05" getLabel="ribbon.GetLabel" onAction="ribbon.OnAction"/>
            <button id="rate075" getLabel="ribbon.GetLabel" onAction="ribbon.OnAction"/>
            <button id="rate10" getLabel="ribbon.GetLabel" onAction="ribbon.OnAction"/>
            <button id="rate15" getLabel="ribbon.GetLabel" onAction="ribbon.OnAction"/>
            <button id="rate20" getLabel="ribbon.GetLabel" onAction="ribbon.OnAction"/>
          </menu>
        </group>
        <group id="serviceGroup" label="服务">
          <button id="checkStatus" label="状态检查" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="状态检查" supertip="检查本地朗读服务、语音引擎和播放器探测结果。"/>
          <button id="aboutAddin" label="关于朗读" size="large" getImage="ribbon.GetImage" onAction="ribbon.OnAction" screentip="关于朗读" supertip="查看加载项名称、版本、开发者和说明文档链接。"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
